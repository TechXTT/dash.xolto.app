# xolto app frontend — Environment Variables
# Copy this file to .env.local and fill in real values.

# URL of the Go API server
NEXT_PUBLIC_API_URL=http://localhost:8000

# Sentry client DSN for frontend monitoring
NEXT_PUBLIC_SENTRY_DSN=

# Optional local override for release identifier (defaults to Vercel commit SHA)
NEXT_PUBLIC_GIT_SHA=

# Stripe price IDs from your Stripe dashboard (Products → Pricing)
# Leave blank to disable billing UI.
# After the W18 (2026-04-25) tier rename:
#   NEXT_PUBLIC_STRIPE_BUYER_PRICE_ID = mid tier ("Buyer", internal slug "pro").
#     Legacy fallback if unset: NEXT_PUBLIC_STRIPE_PRO_PRICE_ID (deprecated).
#   NEXT_PUBLIC_STRIPE_PRO_PRICE_ID   = top tier ("Pro",   internal slug "power").
#     Legacy fallback if unset: NEXT_PUBLIC_STRIPE_POWER_PRICE_ID (deprecated).
NEXT_PUBLIC_STRIPE_BUYER_PRICE_ID=price_...
NEXT_PUBLIC_STRIPE_PRO_PRICE_ID=price_...
